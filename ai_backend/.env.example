# Copy this file to .env and fill in your values
# cp .env.example .env

# ── AI Keys ─────────────────────────────────────────────────
# Get a free Groq key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Optional — only needed if using Gemini. Leave empty to use Groq.
GEMINI_API_KEY=

# Optional — only needed if using OpenRouter
OPENROUTER_API_KEY=

# ── Auth ─────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=generate_a_random_secret_here_minimum_32_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=60
REFRESH_TOKEN_DAYS=7

# ── App ──────────────────────────────────────────────────────
APP_ENV=development
CORS_ORIGIN=http://localhost:5173

# ── Database — SQLite file path ───────────────────────────────
DATABASE_PATH=./POLO.db

# ── Django integration (fill when ready) ─────────────────────
# DJANGO_API_URL=http://localhost:8000
# DJANGO_SECRET_KEY=optional_shared_secret